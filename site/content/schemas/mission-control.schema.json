{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MissionControl",
  "type": "object",
  "required": ["updated_at", "phase", "checklist"],
  "properties": {
    "updated_at": { "type": "string" },
    "callsign": { "type": "string" },
    "phase": { "type": "string" },
    "launch_target": { "type": "string" },
    "funding_goal_usd": { "type": "number" },
    "checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "item", "phase", "status"],
        "properties": {
          "id": { "type": "string" },
          "item": { "type": "string" },
          "phase": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "in_progress", "blocked", "done", "cancelled"]
          },
          "due": { "type": "string" }
        }
      }
    }
  }
}
