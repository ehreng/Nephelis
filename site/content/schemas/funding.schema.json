{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Funding",
  "type": "object",
  "required": ["tiers", "currency"],
  "properties": {
    "currency": { "type": "string" },
    "success_path": { "type": "string" },
    "cancel_path": { "type": "string" },
    "tiers": {
      "type": "object",
      "required": ["legacy", "dna"],
      "properties": {
        "legacy": { "$ref": "#/definitions/tier" },
        "dna": { "$ref": "#/definitions/tier" }
      }
    }
  },
  "definitions": {
    "tier": {
      "type": "object",
      "required": ["id", "name", "label", "price_usd", "capacity", "baseline_allocated"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "label": { "type": "string" },
        "price_usd": { "type": "number", "minimum": 1 },
        "capacity": { "type": "integer", "minimum": 1 },
        "baseline_allocated": { "type": "integer", "minimum": 0 },
        "description": { "type": "string" }
      }
    }
  }
}
