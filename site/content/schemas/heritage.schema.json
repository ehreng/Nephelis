{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Heritage",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["year", "mission", "type"],
    "properties": {
      "year": { "type": "string" },
      "mission": { "type": "string" },
      "note": { "type": "string" },
      "type": { "type": "string" },
      "highlight": { "type": "boolean" },
      "link": { "type": ["string", "null"] }
    }
  }
}
