{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Timeline",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["year", "event", "status"],
    "properties": {
      "year": { "type": "string", "minLength": 1 },
      "event": { "type": "string", "minLength": 1 },
      "status": {
        "type": "string",
        "enum": ["target", "current", "complete", "background", "future", "planned"]
      }
    },
    "additionalProperties": false
  }
}
