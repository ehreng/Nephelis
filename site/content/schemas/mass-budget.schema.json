{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MassBudget",
  "type": "object",
  "required": ["updated_at", "wet_mass_kg", "elements"],
  "properties": {
    "updated_at": { "type": "string" },
    "wet_mass_kg": { "type": "number" },
    "target_float_altitude_km": { "type": "number" },
    "balloon_volume_m3": { "type": "number" },
    "balloon_diameter_m": { "type": "number" },
    "delta_v_m_s": { "type": "number" },
    "isp_s": { "type": "number" },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "mass_kg_min", "mass_kg_max"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "mass_kg_min": { "type": "number" },
          "mass_kg_max": { "type": "number" },
          "notes": { "type": "string" }
        }
      }
    },
    "contingency": { "type": "string" }
  }
}
